# Containerfile: ASCII to PDF Converter
# Usage:
#   podman build -t ascii-to-pdf .
#   podman run --rm -v /path/to/files:/data ascii-to-pdf input.txt output.pdf

FROM python:3.12-slim

LABEL maintainer="ascii-to-pdf"
LABEL description="Convert ASCII/plain text files to PDF using ReportLab"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir reportlab

# Create working directory
WORKDIR /data

# Copy the conversion script into the image
COPY convert.py /usr/local/bin/convert.py
RUN chmod +x /usr/local/bin/convert.py

# Default entrypoint
ENTRYPOINT ["python", "/usr/local/bin/convert.py"]

# Default command (can be overridden at runtime)
CMD ["--help"]
